# OpenAI 接入配置（前端 Vite 环境变量）
# 复制为 .env.local 后填写真实值

VITE_OPENAI_API_KEY=your_openai_api_key
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# MiniMax M2.5 接入配置
VITE_MINIMAX_API_KEY=
VITE_MINIMAX_MODEL=MiniMax-M2.5
VITE_MINIMAX_GROUP_ID=
VITE_MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2

# Claude 接入配置
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-sonnet-4-20250514
VITE_CLAUDE_API_URL=https://api.anthropic.com/v1/messages

